{
  "name": "icecream-game",
  "version": "1.0.1",
  "description": "Pixel Art Ice Cream Game built with Phaser and Electron",
  "main": "main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron:dev": "electron .",
    "dist:win": "vite build && electron-builder --win portable",
    "cap:sync": "vite build && npx cap sync",
    "cap:android": "npx cap open android"
  },
  "dependencies": {
    "@capacitor/android": "^6.0.0",
    "@capacitor/cli": "^6.0.0",
    "@capacitor/core": "^6.0.0",
    "phaser": "^3.80.1"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3",
    "vite": "^5.2.0"
  },
  "build": {
    "appId": "com.icecream.shop.game",
    "productName": "IceCream Shop Game",
    "win": {
      "target": "portable",
      "icon": "assets/icon.png"
    },
    "files": [
      "dist/**/*",
      "main.js",
      "preload.js"
    ],
    "directories": {
      "output": "release"
    }
  }
}
